# Talk2Campus Backend Environment Variables
# Copy this file to .env and fill in the values before running

MONGO_URL=your_mongodb_connection_string

# Frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# OpenRouteService routing on top of Leaflet + OpenStreetMap
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org

# Event sync behavior
ENGAGE_LOOKBACK_DAYS=30
ENGAGE_RETENTION_DAYS=60
EVENT_SYNC_ENABLED=true
EVENT_SYNC_INTERVAL_MINUTES=180

# AI Assistant
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# JWT Authentication
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookie settings
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
